{
  "expo": {
    "name": "BizRealms",
    "slug": "bizrealms",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bizrealms",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bizrealms.game",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Take profile photos for your avatar",
        "NSPhotoLibraryUsageDescription": "Choose profile photos from gallery",
        "NSLocationWhenInUseUsageDescription": "Show your city on the game map"
      }
    },
    "android": {
      "package": "com.bizrealms.game",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0f1723"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#0f1723"
        }
      ],
      "expo-localization",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#4CAF50"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
